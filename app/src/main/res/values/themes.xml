<?xml version="1.0" encoding="utf-8"?>
<resources>
    <style name="Theme.Gote" parent="Theme.MaterialComponents.DayNight.NoActionBar">
        <item name="colorPrimary">@color/gote_dark_green</item>
        <item name="colorPrimaryVariant">@color/gote_dark_green</item>
        <item name="colorOnPrimary">@color/white</item>
        <item name="colorSecondary">@color/gote_light_green</item>
        <item name="colorOnSecondary">@color/black</item>
        <item name="android:windowBackground">@color/gote_dark_green</item>
    </style>

    <style name="GoteHeading" parent="TextAppearance.MaterialComponents.Headline4">
        <item name="android:fontFamily">@font/goldman_bold</item>
        <item name="android:textColor">@color/white</item>
        <item name="android:textStyle">bold</item>
    </style>

    <style name="GoteButton" parent="Widget.MaterialComponents.Button">
        <item name="android:backgroundTint">@color/gote_light_green</item>
        <item name="android:textColor">@color/gote_dark_green</item>
        <item name="android:fontFamily">@font/goldman_regular</item>
        <item name="android:textStyle">bold</item>
        <item name="cornerRadius">8dp</item>
    </style>
</resources>