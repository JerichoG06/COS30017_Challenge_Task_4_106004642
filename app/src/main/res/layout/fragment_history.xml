<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gote_dark_green">

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Round History"
        android:fontFamily="@font/goldman_bold"
        android:textColor="@color/white"
        android:textSize="28sp"
        android:gravity="center"
        android:paddingTop="6dp" />

    <TextView
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:text="Click Entries to See Their Full Info"
        android:textColor="@color/white"
        android:textSize="12sp"
        android:gravity="center"
        android:layout_marginBottom="8dp" />

    <!-- Light green area takes all remaining space -->
    <FrameLayout
        android:id="@+id/frameContent"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="@color/gote_light_green">

        <androidx.recyclerview.widget.RecyclerView
            android:id="@+id/rvHistory"
            android:layout_width="match_parent"
            android:layout_height="match_parent"
            android:clipToPadding="false" />

        <TextView
            android:id="@+id/tvEmptyHistory"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="No rounds saved yet."
            android:textColor="@color/gote_dark_green"
            android:gravity="center"
            android:padding="32dp"
            android:layout_gravity="center"
            android:visibility="gone" />

    </FrameLayout>

</LinearLayout>
