<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:gravity="center"
    android:background="@color/gote_dark_green"
    android:padding="32dp">

    <ImageView
        android:id="@+id/ivLogo"
        android:layout_width="200dp"
        android:layout_height="200dp"
        android:src="@drawable/ic_gote_logo"
        android:contentDescription="Gote Logo"
        android:scaleType="centerCrop"
        android:layout_marginBottom="16dp" />

    <TextView
        android:id="@+id/tvLogo"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:text="GOTE"
        android:textSize="48sp"
        android:fontFamily="@font/goldman_regular"
        android:textColor="@color/white"
        android:layout_marginBottom="48dp" />

    <Button
        android:id="@+id/btnStartRound"
        style="@style/GoteButton"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:text="Start Round"
        android:gravity="center"
        android:fontFamily="@font/goldman_regular"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnHistory"
        style="@style/GoteButton"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:text="Round History"
        android:gravity="center"
        android:fontFamily="@font/goldman_regular"
        android:layout_marginBottom="16dp" />

    <Button
        android:id="@+id/btnFavourites"
        style="@style/GoteButton"
        android:layout_width="240dp"
        android:layout_height="wrap_content"
        android:text="Favourites"
        android:gravity="center"
        android:fontFamily="@font/goldman_regular" />

</LinearLayout>