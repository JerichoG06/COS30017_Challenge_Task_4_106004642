<?xml version="1.0" encoding="utf-8"?>
<LinearLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:background="@color/gote_dark_green">

    <TextView
        android:id="@+id/tvRoundTitle"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:textSize="22sp"
        android:fontFamily="@font/goldman_bold"
        android:textColor="@color/white"
        android:gravity="center"
        android:padding="12dp"
        android:text="Round" />

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:fillViewport="true">

        <HorizontalScrollView
            android:id="@+id/horizontalScroll"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:fillViewport="true">

            <LinearLayout
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:minWidth="360dp">

                <LinearLayout
                    android:id="@+id/limeContainer"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:background="@color/gote_light_green">

                    <androidx.recyclerview.widget.RecyclerView
                        android:id="@+id/rvHoles"
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:nestedScrollingEnabled="false"
                        android:overScrollMode="never" />

                    <Button
                        android:id="@+id/btnAddHole"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="+ Add Hole"
                        android:textColor="@color/black"
                        android:backgroundTint="@color/gote_add_hole"
                        android:layout_margin="8dp" />

                </LinearLayout>

            </LinearLayout>

        </HorizontalScrollView>

    </androidx.core.widget.NestedScrollView>
    
    <!-- Fixed Bottom bar -->
    <LinearLayout
        android:id="@+id/bottomBar"
        android:layout_width="match_parent"
        android:layout_height="72dp"
        android:orientation="horizontal"
        android:gravity="center"
        android:background="@color/gote_dark_green"
        android:padding="12dp">
        
        <Button
            android:id="@+id/btnBack"
            style="@style/Widget.MaterialComponents.Button.OutlinedButton"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="←"
            android:textColor="@color/white"
            android:strokeColor="@color/white"
            android:layout_marginEnd="32dp" />

        <Button
            android:id="@+id/btnSaveRound"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Save Round" />

    </LinearLayout>

</LinearLayout>